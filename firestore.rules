rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    match /rooms/{room} {

      function hostUid() {
        return get(/databases/$(database)/documents/rooms/$(room)).data.hostUid;
      }
      function isHost() { return signedIn() && hostUid() == request.auth.uid; }
      function inRoom() {
        return signedIn()
            && exists(/databases/$(database)/documents/rooms/$(room)/members/$(request.auth.uid));
      }

      // เจ้าของห้องเงียบไปนานแค่ไหนแล้ว — อ่านจากเอกสารของเขาเอง
      // ปลอมไม่ได้ เพราะแต่ละคนเขียน lastSeen ได้แค่ของตัวเอง
      // และ lastSeen เป็นเวลาจากเซิร์ฟเวอร์ ไม่ใช่นาฬิกาเครื่องผู้เล่น
      function hostSilent() {
        let p = /databases/$(database)/documents/rooms/$(room)/members/$(resource.data.hostUid);
        return !exists(p)
            || request.time.toMillis() - get(p).data.lastSeen.toMillis() > 25000;
      }

      // การยึดตำแหน่ง: เปลี่ยนได้แค่ hostUid กับ touchedAt ตั้งเป็นตัวเองเท่านั้น
      // และต้องนั่งอยู่ในห้องนี้จริง
      function takingOver() {
        return signedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['hostUid', 'touchedAt'])
            && request.resource.data.hostUid == request.auth.uid
            && inRoom()
            && hostSilent();
      }

      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.hostUid == request.auth.uid
                    && room.size() == 4;
      // state ของเกมเขียนได้เฉพาะเจ้าของห้อง — หัวใจของ Host Authority
      allow update: if (signedIn() && resource.data.hostUid == request.auth.uid)
                    || takingOver();
      // เจ้าของห้องลบห้องตัวเองได้ · ห้องที่ไม่มีใครแตะเกิน 12 ชั่วโมงใครก็เก็บกวาดได้
      function staleDoc(d) {
        return d.touchedAt == null
            || request.time.toMillis() - d.touchedAt.toMillis() > 43200000;
      }
      function roomStale() {
        return signedIn()
            && exists(/databases/$(database)/documents/rooms/$(room))
            && staleDoc(get(/databases/$(database)/documents/rooms/$(room)).data);
      }
      allow delete: if signedIn()
                    && (resource.data.hostUid == request.auth.uid || staleDoc(resource.data));

      match /members/{uid} {
        allow read: if signedIn();
        // เขียนเอกสารของตัวเองได้ · เจ้าของห้องเขียนของทุกคนได้
        // (ต้องได้ เพราะเจ้าของห้องแจกเลขที่นั่งและล้างสถานะ Ready)
        allow write: if signedIn() && (request.auth.uid == uid || isHost());
        allow delete: if signedIn() && (request.auth.uid == uid || isHost() || roomStale());
      }

      // คำขอ: ยื่นได้ในนามตัวเองเท่านั้น อ่านและลบได้เฉพาะเจ้าของห้อง
      // ผู้เล่นจึงเปลี่ยนสถานะเกมเองไม่ได้ ทำได้แค่ขอให้เจ้าของห้องตัดสิน
      match /actions/{id} {
        allow read:   if isHost();
        allow create: if inRoom() && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isHost() || roomStale();
      }

      // ไพ่ในมือและสำรับ: เจ้าตัวอ่านได้คนเดียว เจ้าของห้องอ่านได้เพราะต้องตัดสิน
      // ต้องเป็น subcollection — Security Rules คุมได้แค่ระดับเอกสาร ไม่ใช่ระดับฟิลด์
      match /secrets/{uid} {
        allow read:  if signedIn() && (request.auth.uid == uid || isHost());
        allow write: if isHost();
        allow delete: if isHost() || roomStale();
      }

      // รูปประจำตัว: แยกออกมาจากเอกสารสมาชิกเพราะสมาชิกถูกเขียนทับทุก 5 วินาที
      // ถ้าเก็บรวมกัน Firestore จะส่งรูปซ้ำให้ทุกคนทุกครั้งที่มีสัญญาณชีพ
      // จำกัดความยาวไว้กันเอกสารบวมและกันคนยัดไฟล์ใหญ่เข้ามา
      match /avatars/{uid} {
        allow read:   if signedIn();
        allow create, update: if signedIn() && request.auth.uid == uid
                      && request.resource.data.img is string
                      && request.resource.data.img.size() <= 70000;
        allow delete: if signedIn() && (request.auth.uid == uid || isHost() || roomStale());
      }

      // แชท: ทุกคนในห้องอ่านได้ · เขียนได้ในนามตัวเองเท่านั้น แก้ย้อนหลังไม่ได้
      // เจ้าของห้องลบข้อความเก่าทิ้งได้เพื่อไม่ให้ห้องบวม
      match /chat/{id} {
        allow read:   if signedIn();
        allow create: if inRoom()
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 300;
        allow update: if false;
        allow delete: if isHost() || roomStale();
      }
    }

    match /{document=**} { allow read, write: if false; }
  }
}
